# Agentic Stack environment. Copy to .env.local for `vercel dev`, or set in the Vercel project.
# Everything is OPTIONAL: with no vars set, the app runs in public mode
# (browse + localStorage saves). Add these to switch on accounts + cross-device save.

# --- WorkOS AuthKit (passwordless email sign-in) ---
# Free up to 1M monthly active users. Dashboard: https://dashboard.workos.com
WORKOS_API_KEY=
WORKOS_CLIENT_ID=
# Must match a redirect configured in the WorkOS dashboard (AuthKit > Redirects)
WORKOS_REDIRECT_URI=http://localhost:3000/api/auth/callback
# Random 32+ char secret used to seal the session cookie (generate: openssl rand -base64 32)
WORKOS_COOKIE_PASSWORD=

# --- Neon Postgres (cross-device saved pains + PRDs) ---
# Free serverless tier. Dashboard: https://console.neon.tech
# Without it, saves fall back to the browser's localStorage.
DATABASE_URL=

# --- PRD generation (Claude) ---
# Required for the PRD Builder to generate. Without it the builder shows a manual
# fallback and the rest of the app stays free. Get a key: https://console.anthropic.com
ANTHROPIC_API_KEY=
# Optional overrides. Default model is Opus 4.8 (best quality; ~a few cents per PRD).
# Switch to claude-sonnet-4-6 or claude-haiku-4-5 to cut cost/latency.
PRD_MODEL=claude-opus-4-8
# Effort: low | medium | high | xhigh | max. Lower = faster/cheaper. Default medium
# keeps generation inside the serverless time limit.
PRD_EFFORT=medium

# Public base URL of the deployment (used to build auth redirects)
APP_URL=http://localhost:3000
